// ─────────────────────────────────────────────────────────────
// CrmErp — Prisma Schema v1
// PostgreSQL 16 | Multi-tenant | Domain-driven modules
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum OrderStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum StockMovementType {
  IN
  OUT
}

enum CashMovementType {
  IN
  OUT
}

enum DocumentType {
  DNI
  CUIT
  PASSPORT
}

// ── Core ─────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  roles         Role[]
  branches      Branch[]
  customers     Customer[]
  contacts      Contact[]
  products      Product[]
  categories    Category[]
  warehouses    Warehouse[]
  stockMovements StockMovement[]
  quotes        Quote[]
  orders        Order[]
  invoices      Invoice[]
  cashRegisters CashRegister[]
  cashMovements CashMovement[]

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  refreshTokens RefreshToken[]
  roles         UserRole[]

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  users           UserRole[]
  rolePermissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String
  resource    String
  action      String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model UserRole {
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId String
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Branch {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customers     Customer[]
  quotes        Quote[]
  orders        Order[]
  invoices      Invoice[]
  cashRegisters CashRegister[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("branches")
}

// ── CRM ──────────────────────────────────────────────────────

model Customer {
  id             String       @id @default(cuid())
  tenantId       String       @map("tenant_id")
  branchId       String?      @map("branch_id")
  name           String
  email          String?
  phone          String?
  documentType   DocumentType @map("document_type")
  documentNumber String       @map("document_number")
  address        String?
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  contacts Contact[]
  quotes   Quote[]
  orders   Order[]
  invoices Invoice[]

  @@unique([tenantId, documentType, documentNumber])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("customers")
}

model Contact {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  customerId String   @map("customer_id")
  name       String
  email      String?
  phone      String?
  position   String?
  createdAt  DateTime @default(now())

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("contacts")
}

// ── Inventory ────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  code        String
  name        String
  description String?
  categoryId  String?  @map("category_id")
  unitPrice   Decimal  @map("unit_price")
  costPrice   Decimal  @map("cost_price")
  stock       Int      @default(0)
  minStock    Int      @default(0) @map("min_stock")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  category       Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  quoteItems     QuoteItem[]
  orderItems     OrderItem[]
  invoiceItems   InvoiceItem[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("products")
}

model Category {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  products Product[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("categories")
}

model Warehouse {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  name      String
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("warehouses")
}

model StockMovement {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  productId   String            @map("product_id")
  warehouseId String?           @map("warehouse_id")
  type        StockMovementType
  quantity    Int
  reference   String?
  createdAt   DateTime          @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("stock_movements")
}

// ── Sales ────────────────────────────────────────────────────

model Quote {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  branchId   String?     @map("branch_id")
  customerId String      @map("customer_id")
  number     String
  date       DateTime    @default(now())
  status     QuoteStatus
  subtotal   Decimal
  tax        Decimal
  total      Decimal
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch?    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    QuoteItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("quotes")
}

model QuoteItem {
  id        String   @id @default(cuid())
  quoteId   String   @map("quote_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price")
  subtotal  Decimal

  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("quote_items")
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  branchId   String?     @map("branch_id")
  customerId String      @map("customer_id")
  number     String
  date       DateTime    @default(now())
  status     OrderStatus
  subtotal   Decimal
  tax        Decimal
  total      Decimal
  notes      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch?    @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer Customer   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    OrderItem[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String   @map("order_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price")
  subtotal  Decimal

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Invoice {
  id         String         @id @default(cuid())
  tenantId   String         @map("tenant_id")
  branchId   String?        @map("branch_id")
  customerId String         @map("customer_id")
  number     String
  date       DateTime       @default(now())
  status     InvoiceStatus
  subtotal   Decimal
  tax        Decimal
  total      Decimal
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch   Branch?         @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items    InvoiceItem[]
  payments InvoicePayment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("invoices")
}

model InvoiceItem {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price")
  subtotal  Decimal

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("invoice_items")
}

model InvoicePayment {
  id        String   @id @default(cuid())
  invoiceId String   @map("invoice_id")
  method    String
  amount    Decimal
  reference String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_payments")
}

// ── Cash ─────────────────────────────────────────────────────

model CashRegister {
  id        String    @id @default(cuid())
  tenantId  String    @map("tenant_id")
  branchId  String?   @map("branch_id")
  name      String
  balance   Decimal   @default(0)
  openedAt  DateTime? @map("opened_at")
  closedAt  DateTime? @map("closed_at")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch        Branch?        @relation(fields: [branchId], references: [id], onDelete: Restrict)
  cashMovements CashMovement[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, id])
  @@map("cash_registers")
}

model CashMovement {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  cashRegisterId String           @map("cash_register_id")
  type           CashMovementType
  amount         Decimal
  description    String?
  reference      String?
  createdAt      DateTime         @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  cashRegister CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, id])
  @@map("cash_movements")
}
