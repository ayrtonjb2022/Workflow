{
  "name": "@crm/api",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@crm/events": "workspace:*",
    "@crm/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/type-provider-typebox": "^5.1.0",
    "@prisma/client": "^5.22.0",
    "@sinclair/typebox": "^0.34.0",
    "bcrypt": "^6.0.0",
    "fastify": "^5.3.0",
    "jsonwebtoken": "^9.0.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/xlsx": "^0.0.36",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.9"
  }
}
